/target
# Codecov lcov output (`make coverage-lcov`)
/lcov.info
ROADMAP.md
QUALITY.md
PLAN.md
# local design/planning artifacts (specs, plans, product discovery, dev
# runbooks, bug journal, arc results): local working notes, not committed
/docs/plans/
/docs/specs/*
/docs/product/
/docs/dev/
/docs/bugs/
/docs/results/
/docs/deps/
# transient screenshots dropped at the repo root (current.png, crates-io.png, …)
/*.png
/assets/ignore/

# Codex CLI agent's per-repo scratch (its `rules/` + session state).
.codex/

# mdBook build output (`make book` / `mdbook build`)
/docs/book/book/

# `make site`'s scratch copy of site/ (whatsnew.html generated in place there,
# same scratch-dir name the pages workflow assembles into; see Makefile).
/_site/

# Python bytecode cache (scripts/*.py are run directly, e.g. `python3
# scripts/site-changelog.py`, which creates this as a side effect).
__pycache__/

# Playwright e2e (`make e2e`) — Node tooling and both servers' scratch decks
# copies (.tmp/kids/, .tmp/adult/); fixtures/ itself IS committed (see
# e2e/README.md).
/e2e/node_modules/
/e2e/.tmp/
/e2e/test-results/
/e2e/playwright-report/
# e2e/shots/capture.cjs's own scratch copies of ~/alix-demo and ~/alix-kids
# (never the originals — see the script's header comment).
/e2e/shots/.tmp/
# A progress store is per-run state, never a fixture — the suite must start
# from a fresh (no store) deck to exercise the never-seen/acquire path.
/e2e/fixtures/decks/**/progress.json
/e2e/fixtures/decks/**/recent.json
